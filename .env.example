# ── NETWORK ──────────────────────────────────────────────────────────
NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── DEPLOYER ─────────────────────────────────────────────────────────
DEPLOYER_ADDRESS=GCX...YOUR_DEPLOYER_ADDRESS

# ── ORACLE ───────────────────────────────────────────────────────────
ORACLE_ADDRESS=GBG...YOUR_ORACLE_ADDRESS

# ── TESTNET USDC (Stellar testnet USDC SAC) ───────────────────────────
USDC_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# ── CONTRACT ADDRESSES (fill after deploy) ────────────────────────────
AGENT_REGISTRY_CONTRACT_ID=C...
VALIDATION_REGISTRY_CONTRACT_ID=C...
CAMPAIGN_ORACLE_CONTRACT_ID=C...
DEAL_VAULT_CONTRACT_ID=C...
PACT_MARKET_CONTRACT_ID=C...

# ── AI AGENTS ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
AGENT_RUNTIME_PORT=8000

# ── FRONTEND ──────────────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK=testnet
